{
  "build": {
    "beforeDevCommand": "cd .. && npm run dev",
    "devPath": "http://localhost:5173",
    "beforeBuildCommand": "cd .. && npm run build",
    "distDir": "../frontend/build",
    "devtools": true
  },
  "package": {
    "productName": "VibeX Workbench",
    "version": "0.1.0"
  },
  "tauri": {
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "ai.vibex.workbench",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png"
      ]
    },
    "windows": [
      {
        "title": "VibeX Workbench",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "shell": {
      "open": true
    }
  }
}
